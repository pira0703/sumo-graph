# Supabase
NEXT_PUBLIC_SUPABASE_URL=op://Personal/Supabase sumo-graph/url
NEXT_PUBLIC_SUPABASE_ANON_KEY=op://Personal/Supabase sumo-graph/anon_key
SUPABASE_SERVICE_ROLE_KEY=op://Personal/Supabase sumo-graph/secret_keys

# Basic認証（本番 /admin 保護用）
BASIC_AUTH_USER=op://Personal/Supabase sumo-graph/basic_auth_user
BASIC_AUTH_PASSWORD=op://Personal/Supabase sumo-graph/basic_auth_password

# AI画像生成 (fal.ai FLUX Schnell)
# https://fal.ai/dashboard/keys でAPIキーを取得して
# 1Password の「Supabase sumo-graph」アイテムの fal_key フィールドに保存
FAL_KEY=op://Personal/Supabase sumo-graph/fal_key
